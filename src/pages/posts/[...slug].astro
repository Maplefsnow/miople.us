---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return posts.map((post, idx) => {
    const slug = post.id.replace(/\.(md|mdx)$/, '');
    // Find prev/next within the same language
    const sameLang = posts.filter((p) => p.data.lang === post.data.lang);
    const i = sameLang.findIndex((p) => p.id === post.id);
    const newer = sameLang[i - 1] ?? null;
    const older = sameLang[i + 1] ?? null;
    return {
      params: { slug },
      props: {
        post,
        prev: older
          ? { slug: older.id.replace(/\.(md|mdx)$/, ''), title: older.data.title }
          : null,
        next: newer
          ? { slug: newer.id.replace(/\.(md|mdx)$/, ''), title: newer.data.title }
          : null,
      },
    };
  });
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---
<PostLayout post={post} prev={prev} next={next}>
  <Content />
</PostLayout>
